# ASR endpoint
ASR_URL=http://127.0.0.1:8011
ASR_LANGUAGE=en
ASR_CHUNK_MS=160
ASR_TRANSCRIBE_PATH=/transcribe
ASR_AUDIO_FIELD=audio_file
ASR_MODEL=
ASR_API_KEY=

# Optional: local Nemotron NIM helper defaults
NEMOTRON_ASR_URL=http://127.0.0.1:9000
NEMOTRON_ASR_MODEL=nvidia/nemotron-asr-streaming
NEMOTRON_NIM_IMAGE=nvcr.io/nim/nvidia/nemotron-asr-streaming-riva-v1:latest

# OpenAI-compatible LLM endpoint
LLM_BASE_URL=http://127.0.0.1:30000/v1
LLM_MODEL=HuggingFaceTB/SmolLM2-360M-Instruct
LLM_API_KEY=EMPTY

# TTS endpoint
TTS_URL=http://127.0.0.1:8012
TTS_MODE=http_synthesize
TTS_MODEL=piper/en_US-lessac-medium
TTS_VOICE=Chelsie
TTS_SPLIT_GRANULARITY=sentence

# Benchmark profile
CALLS=20
CONCURRENCY=5
SAMPLE_POOL=5
WAIT_FOR_HEALTH=1

# Full-duplex behavior
LLM_STREAM_MODE=aggressive
LLM_AGGRESSIVE_MIN_TOKENS=5
ENABLE_BARGE_IN=1
BARGE_IN_MIN_SPEECH_MS=120
VAD_STREAMING=1
VAD_PARTIAL_SEGMENT_MS=320
VAD_MAX_STREAM_SEGMENT_MS=1280

# Transport selection: http or webrtc
TRANSPORT=http
ASR_WEBRTC_OFFER_URL=
LLM_WEBRTC_OFFER_URL=
TTS_WEBRTC_OFFER_URL=
